#define IMG_HEIGHT  8     // Chiều cao ảnh test
#define IMG_SIZE    (IMG_WIDTH * IMG_HEIGHT)

// Offset trong SDRAM
#define SDRAM_INPUT_OFFSET   0        // Ảnh đầu vào tại 0x00800000
#define SDRAM_OUTPUT_OFFSET  (IMG_SIZE * 2) // Ảnh đầu ra (cách 2 byte/pixel vì SDRAM 16-bit)

// ============================================================
// Hàm ghi pixel vào SDRAM (16-bit access)
// ============================================================
static inline void sdram_write_pixel(uint32_t offset, uint8_t value)
{
    volatile uint16_t *ptr = (volatile uint16_t *)(SDRAM_BASE + offset*2);
    *ptr = (uint16_t)value;
}

// ============================================================
// Hàm đọc pixel từ SDRAM
// ============================================================
static inline uint8_t sdram_read_pixel(uint32_t offset)
{
    volatile uint16_t *ptr = (volatile uint16_t *)(SDRAM_BASE + offset * 2);
    return (uint8_t)(*ptr & 0xFF);
}

// ============================================================
// Hàm ghi 9 pixel vào PIO → kích hoạt median hardware
// ============================================================
static inline void write_window_to_pio(uint8_t p[9])
{
    IOWR_ALTERA_AVALON_PIO_DATA(PIO_P0_BASE, p[0]);
    IOWR_ALTERA_AVALON_PIO_DATA(PIO_P1_BASE, p[1]);
    IOWR_ALTERA_AVALON_PIO_DATA(PIO_P2_BASE, p[2]);
    IOWR_ALTERA_AVALON_PIO_DATA(PIO_P3_BASE, p[3]);
    IOWR_ALTERA_AVALON_PIO_DATA(PIO_P4_BASE, p[4]);
    IOWR_ALTERA_AVALON_PIO_DATA(PIO_P5_BASE, p[5]);
    IOWR_ALTERA_AVALON_PIO_DATA(PIO_P6_BASE, p[6]);
    IOWR_ALTERA_AVALON_PIO_DATA(PIO_P7_BASE, p[7]);
    IOWR_ALTERA_AVALON_PIO_DATA(PIO_P8_BASE, p[8]);
}

// ============================================================
// Hàm đọc kết quả median từ PIO_9
// ============================================================
static inline uint8_t read_median_result(void)
{
    // Thêm delay nhỏ để median hardware ổn định
    // (combinational logic, thường chỉ cần 1 cycle)
    volatile int i;
    for (i = 0; i < 10; i++);

    return (uint8_t)(IORD_ALTERA_AVALON_PIO_DATA(PIO_OUT_MEDIAN_BASE) & 0xFF);
}

// ============================================================
// Hàm tính median bằng phần mềm (để verify hardware)
// ============================================================
static uint8_t software_median(uint8_t p[9])
{
    uint8_t sorted[9];
    memcpy(sorted, p, 9);

    // Bubble sort đơn giản
    int i, j;
    for (i = 0; i < 9; i++) {
        for (j = i + 1; j < 9; j++) {
            if (sorted[i] > sorted[j]) {
                uint8_t tmp = sorted[i];
                sorted[i] = sorted[j];
                sorted[j] = tmp;
            }
        }
    }
    return sorted[4]; // Median là phần tử thứ 5
}

// ============================================================
// In ảnh ra terminal
// ============================================================
static void print_image(const char *title, uint8_t *img, int w, int h)
{
    printf("\n=== %s (%dx%d) ===\n", title, w, h);
    int r, c;
    for (r = 0; r < h; r++) {
        for (c = 0; c < w; c++) {
            printf("%4d", img[r * w + c]);
        }
        printf("\n");
    }
}

