// ============================================================

#define SDRAM_BASE     NEW_SDRAM_CONTROLLER_0_BASE  // 0x00800000

// PIO base addresses - lấy từ system.h được generate
#define PIO_P0_BASE    PIO_0_BASE
#define PIO_P1_BASE    PIO_1_BASE
#define PIO_P2_BASE    PIO_2_BASE
#define PIO_P3_BASE    PIO_3_BASE
#define PIO_P4_BASE    PIO_4_BASE
#define PIO_P5_BASE    PIO_5_BASE
#define PIO_P6_BASE    PIO_6_BASE
#define PIO_P7_BASE    PIO_7_BASE
#define PIO_P8_BASE    PIO_8_BASE
